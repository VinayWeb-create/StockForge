# StockForge Environment Variables

# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=false
PORT=5000

# MongoDB (Use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGO_DB_NAME=stockforge

# JWT
JWT_SECRET_KEY=your-jwt-secret-key

# Redis (Use Redis Cloud for production)
# Format: redis://default:password@host:port/0
REDIS_URL=redis://default:your-redis-password@redis-host:10787/0

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
